# TaskFlow environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=taskflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:password@localhost:5432/taskflow?sslmode=disable

# ── Backend ───────────────────────────────────────────────────────────────────
# IMPORTANT: Change JWT_SECRET to a long random string in production.
# Never commit a real .env file — only commit .env.example.
JWT_SECRET=secret_key
PORT=8080

# ── Migrations ────────────────────────────────────────────────────────────────
# For local development (running go run outside Docker):
#   MIGRATIONS_PATH=file://migrations
# For Docker (default, leave blank):
#   MIGRATIONS_PATH=
MIGRATIONS_PATH=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Leave empty when using nginx proxy (docker compose setup)
# Set to http://localhost:8080 for direct development without the proxy
VITE_API_URL=
